{
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "files.exclude": {
    "**/node_modules": true
  },
  "search.exclude": {},
  "tailwindCSS.experimental.configFile": {
    "src/styles/app.css": "src/**"
  },
  "js/ts.tsdk.path": "node_modules/typescript/lib"
}
