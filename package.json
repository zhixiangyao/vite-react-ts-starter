{
  "name": "vite-react-ts-starter",
  "type": "module",
  "version": "0.1.0",
  "author": "zhixiangyao <blueskyzx@icloud.com> <https://github.com/zhixiangyao>",
  "license": "MIT",
  "homepage": "https://github.com/zhixiangyao/vite-react-ts-starter",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhixiangyao/vite-react-ts-starter.git"
  },
  "engines": {
    "node": ">=24.15.0",
    "pnpm": ">=10.33.2"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "pnpm typecheck && vite build",
    "preview": "pnpm build && vite preview",
    "preview:dist": "vite preview",
    "typecheck": "tsc -b",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "lint:css": "stylelint \"./**/*.css\" --cache --cache-location node_modules/.cache/stylelint/",
    "lint-staged": "lint-staged",
    "postinstall": "simple-git-hooks"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "clsx": "2.1.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-is": "19.2.5",
    "react-router": "7.14.2",
    "react-router-dom": "7.14.2",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.4",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "lint-staged": "16.4.0",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "simple-git-hooks": "2.13.1",
    "stylelint": "17.9.1",
    "stylelint-config-standard": "40.0.0",
    "stylelint-order": "8.1.1",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vite-plugin-checker": "0.13.0",
    "vite-plugin-compression": "0.5.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "**/*.{js,cjs,mjs,jsx,ts,mts,tsx}": [
      "pnpm lint:check"
    ],
    "**/*.{js,cjs,mjs,jsx,ts,mts,tsx,html,md,json,css,yaml,yml}": [
      "pnpm fmt:check"
    ],
    "**/*.css": [
      "stylelint --cache --cache-location node_modules/.cache/stylelint/"
    ]
  }
}
